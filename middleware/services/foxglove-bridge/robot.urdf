<?xml version="1.0"?>
<robot name="rabbit_figure">

  <!--
    Visual mesh is the actual Meshy AI rabbit GLB, converted to STL
    (Y-up→Z-up rotation applied, scaled to 0.35m, feet at Z=0).
    Served via fetchAsset: package://robot_pkg/meshes/bunny.stl
  -->

  <link name="base_link">
    <visual>
      <!-- STL is Y-up (GLTF native); rotate -90° around X to stand upright in Z-up URDF frame -->
      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="http://localhost:8765/meshes/bunny.stl"/>
      </geometry>
    </visual>
    <collision>
      <!-- Bounding box: 0.21m wide × 0.15m deep × 0.35m tall, centered at mid-height -->
      <origin xyz="0 0 0.175" rpy="0 0 0"/>
      <geometry><box size="0.21 0.15 0.35"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.175" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.025" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.010"/>
    </inertial>
  </link>

</robot>
